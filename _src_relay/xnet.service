[Unit]
Description=XNET Relay
After=network.target

[Service]
Type=simple
User=xnet
WorkingDirectory=/opt/xnet-relay
ExecStart=/usr/bin/node /opt/xnet-relay/xnet-relay.js
Restart=always
RestartSec=3

# Zero logging — stdout/stderr to /dev/null
StandardOutput=null
StandardError=null

# No journal capture
SyslogIdentifier=

# Harden the process
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true

[Install]
WantedBy=multi-user.target
